        "finance",
        "utilities",
        "food"
    ],
    "lang": "bn",
    "dir": "ltr",
    "related_applications": [
        {
            "platform": "play",
            "url": "https://play.google.com/store/apps/details?id=software.kangal.www.twa",
            "id": "software.kangal.www.twa"
        }
    ],
