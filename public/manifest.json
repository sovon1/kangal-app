{
    "name": "KANGAL - Mess Management",
    "short_name": "KANGAL",
    "description": "Track meals, split bazaar costs, and manage finances for your university mess.",
    "start_url": "/dashboard",
    "scope": "/",
    "id": "/dashboard",
    "display": "standalone",
    "display_override": [
        "standalone",
        "minimal-ui"
    ],
    "background_color": "#09090b",
    "theme_color": "#16a34a",
    "orientation": "portrait-primary",
    "categories": [
        "finance",
        "utilities",
        "food"
    ],
    "prefer_related_applications": false,
    "launch_handler": {
        "client_mode": "navigate-existing"
    },
    "icons": [
        {
            "src": "/icons/icon-192.svg",
            "sizes": "192x192",
            "type": "image/svg+xml",
            "purpose": "any"
        },
        {
            "src": "/icons/icon-512.png",
            "sizes": "512x512",
            "type": "image/png",
            "purpose": "any"
        },
        {
            "src": "/icons/icon-512.png",
            "sizes": "512x512",
            "type": "image/png",
            "purpose": "maskable"
        }
    ],
    "screenshots": [
        {
            "src": "/icons/icon-512.png",
            "sizes": "512x512",
            "type": "image/png",
            "form_factor": "narrow",
            "label": "KANGAL Mess Management Dashboard"
        }
    ],
    "shortcuts": [
        {
            "name": "Toggle Meals",
            "short_name": "Meals",
            "description": "Toggle today's meals on/off",
            "url": "/dashboard/meals",
            "icons": [
                {
                    "src": "/icons/icon-192.svg",
                    "sizes": "192x192"
                }
            ]
        },
        {
            "name": "Add Bazaar",
            "short_name": "Bazaar",
            "description": "Add today's bazaar expenses",
            "url": "/dashboard/bazaar",
            "icons": [
                {
                    "src": "/icons/icon-192.svg",
                    "sizes": "192x192"
                }
            ]
        },
        {
            "name": "View Balance",
            "short_name": "Balance",
            "description": "Check your current balance",
            "url": "/dashboard",
            "icons": [
                {
                    "src": "/icons/icon-192.svg",
                    "sizes": "192x192"
                }
            ]
        }
    ]
}